{
  "version": 2,

  "functions": {
    "api/*.js": {
      "runtime": "nodejs24.x"
    }
  },

  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    }
  ],

  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/client/index.html" }
  ]
}
