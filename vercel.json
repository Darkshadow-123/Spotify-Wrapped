{
  "version": 2,
  "outputDirectory": "build",
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/manifest.json",
      "dest": "/manifest.json"
    },
    {
      "src": "/favicon.ico",
      "dest": "/favicon.ico"
    },
    {
      "src": "/robots.txt",
      "dest": "/robots.txt"
    },
    {
      "src": "^/(assets|favicons|fonts)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": ".*",
      "dest": "/index.html"
    }
  ]
}
