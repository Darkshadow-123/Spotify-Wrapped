{
  "name": "spotify-profile",
  "version": "0.1.0",
  "description": "Spotify Profile",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "prepare": "echo husky disabled on vercel",
    "client:install": "cd client && npm install",
    "client": "cd client && npm run dev",
    "dev": "concurrently --kill-others-on-fail \"cd client\" \"npm run dev\"",
    "build": "cd client && npm install && npm run build"
  },
  "lint-staged": {
    "*.{js,jsx,css,json,md}": [
      "prettier --write"
    ],
    "*.{js,jsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "connect-history-api-fallback": "^1.6.0",
    "cookie-parser": "1.4.4",
    "cors": "^2.8.5",
    "dotenv": "^8.1.0",
    "express": "~4.17.1",
    "querystring": "~0.2.0",
    "request": "~2.88.0"
  },
  "devDependencies": {
    "@upstatement/eslint-config": "^0.4.3",
    "@upstatement/prettier-config": "^0.3.0",
    "concurrently": "^5.1.0",
    "eslint-config-prettier": "^6.3.0",
    "eslint-plugin-jsx-a11y": "^6.2.3",
    "eslint-plugin-react": "^7.14.3",
    "husky": "^9.1.7",
    "lint-staged": "^10.5.4",
    "prettier": "^1.19.1"
  }
}
